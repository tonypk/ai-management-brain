# Required
DATABASE_URL=postgres://brain:brain@localhost:5432/brain?sslmode=disable
REDIS_URL=redis://localhost:6379
ENCRYPTION_KEY=  # 64 hex chars (32 bytes), generate: openssl rand -hex 32
JWT_SECRET=      # 64 hex chars (32 bytes), generate: openssl rand -hex 32
TELEGRAM_BOT_TOKEN=  # from @BotFather
BOSS_TELEGRAM_ID=    # your Telegram numeric ID

# Optional
ANTHROPIC_API_KEY=   # for AI features (summaries, chase messages, analysis)
TIMEZONE=Asia/Singapore
LOG_LEVEL=info
PORT=8080

# Memory Engine (optional — requires ANTHROPIC_API_KEY, uses free HuggingFace embeddings)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=32
MEMORY_MAX_RECALL=5
MEMORY_MAX_TOKENS=800
MEMORY_SHORT_TERM_DAYS=30
MEMORY_CONSOLIDATION_THRESHOLD=0.85
MEMORY_MAX_PER_TENANT=20000

# Google OAuth (optional, for web dashboard login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/callback

# Stripe billing (optional, for cloud SaaS)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_ENT=

# Slack (optional)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Lark/Feishu (optional)
LARK_APP_ID=
LARK_APP_SECRET=

# PostgreSQL password (for docker-compose.prod.yml)
POSTGRES_PASSWORD=   # change from default in production!
